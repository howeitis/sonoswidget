<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config for SonosWidget.
    Permits cleartext HTTP traffic to ALL destinations because Sonos
    speakers are accessed by raw IP address (e.g. http://192.168.1.10:1400),
    and Android's <domain> rules only match DNS hostnames, not IPs.

    The app only makes cleartext requests to local Sonos speakers (UPnP/SOAP
    on port 1400). All external API traffic (Sonos Cloud, OAuth) uses HTTPS.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
