<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config for SonosWidget.
    Permits cleartext HTTP traffic ONLY to local network ranges
    (required for UPnP/SOAP communication with Sonos speakers).
    All other traffic requires HTTPS.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <!-- Local network ranges where Sonos speakers live -->
        <domain includeSubdomains="true">192.168.0.0</domain>
        <domain includeSubdomains="true">10.0.0.0</domain>
        <domain includeSubdomains="true">172.16.0.0</domain>
    </domain-config>
</network-security-config>
