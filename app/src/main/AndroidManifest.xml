<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network access for Sonos Cloud API (HTTPS) and local UPnP/SOAP (HTTP) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Wi-Fi state detection for local vs. cloud routing -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- Multicast lock for SSDP discovery -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <!-- Android 16 Local Network Protections: required for LAN device access
         (SSDP multicast, mDNS queries, HTTP to local IPs) -->
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES" />

    <!-- Foreground service for real-time playback state updates -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Android 14+: typed foreground service permission (CRITICAL — hard crash without this) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Notification permission for foreground service notification -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Haptic feedback for widget transport controls (HapticHelper) -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".app.SonosApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.SonosWidget"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Companion app Activity (OAuth login, settings) -->
        <activity
            android:name=".app.SonosCompanionActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.SonosWidget">
            <!-- Main launcher entry -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- OAuth callback redirect: sonoswidget://callback -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="sonoswidget"
                    android:host="callback" />
            </intent-filter>
        </activity>

        <!-- Playback polling service (Task 1.5) -->
        <service
            android:name=".service.PlaybackService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Glance widget receiver -->
        <receiver
            android:name=".widget.SonosWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/sonos_widget_info" />
        </receiver>

    </application>

</manifest>
